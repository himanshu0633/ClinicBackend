{
  "info": {
    "name": "Clinic Backend - Visit Flow (Step-by-Step)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Flow-based Postman collection for ClinicBackend APIs: login -> patient -> visit queue -> OPD -> consultation -> tests/lab -> medicines/store -> revisit/timeline."
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "const yyyyMmDd = now.toISOString().slice(0, 10);",
          "const plusDays = (d) => { const x = new Date(now); x.setUTCDate(x.getUTCDate() + d); return x.toISOString().slice(0, 10); };",
          "pm.collectionVariables.set('today', yyyyMmDd);",
          "pm.collectionVariables.set('followUpDate', plusDays(Number(pm.collectionVariables.get('medicineDays') || 5)));",
          "pm.collectionVariables.set('revisitDate', plusDays(7));"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "superAdminEmail", "value": "superadmin@clinicapp.com" },
    { "key": "superAdminPassword", "value": "Admin@123" },
    { "key": "clinicAdminEmail", "value": "clinicadmin@example.com" },
    { "key": "clinicAdminPassword", "value": "Admin@123" },
    { "key": "clinicName", "value": "Flow Demo Clinic" },
    { "key": "clinicPublicEmail", "value": "flowclinic@example.com" },
    { "key": "clinicPublicPhone", "value": "9898989811" },
    { "key": "superAdminToken", "value": "" },
    { "key": "clinicToken", "value": "" },
    { "key": "clinicId", "value": "" },
    { "key": "patientId", "value": "" },
    { "key": "visitId", "value": "" },
    { "key": "serialNo", "value": "1" },
    { "key": "testId", "value": "" },
    { "key": "medicineId", "value": "" },
    { "key": "medicineDays", "value": "5" },
    { "key": "today", "value": "2026-04-22" },
    { "key": "followUpDate", "value": "2026-04-27" },
    { "key": "revisitDate", "value": "2026-04-29" }
  ],
  "item": [
    {
      "name": "0) Health + Auth Setup",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "Register Clinic (Public Route)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/clinics/register",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "clinicName", "value": "{{clinicName}}", "type": "text" },
                { "key": "ownerName", "value": "Dr Flow Owner", "type": "text" },
                { "key": "email", "value": "{{clinicPublicEmail}}", "type": "text" },
                { "key": "phoneNumber", "value": "{{clinicPublicPhone}}", "type": "text" },
                { "key": "registrationNumber", "value": "FLOW-REG-001", "type": "text" },
                { "key": "address", "value": "Main Road", "type": "text" },
                { "key": "country", "value": "India", "type": "text" },
                { "key": "state", "value": "Maharashtra", "type": "text" },
                { "key": "city", "value": "Pune", "type": "text" },
                { "key": "fullAddress", "value": "Main Road, Pune", "type": "text" },
                { "key": "pincode", "value": "411001", "type": "text" },
                { "key": "adminName", "value": "Clinic Admin", "type": "text" },
                { "key": "adminEmail", "value": "{{clinicAdminEmail}}", "type": "text" },
                { "key": "password", "value": "{{clinicAdminPassword}}", "type": "text" },
                { "key": "subscriptionPlan", "value": "premium", "type": "text" },
                { "key": "clinicType", "value": "general", "type": "text" },
                { "key": "doctorCount", "value": "2", "type": "text" },
                { "key": "staffCount", "value": "5", "type": "text" },
                { "key": "consultationFee", "value": "300", "type": "text" },
                { "key": "openingHours", "value": "09:00-19:00", "type": "text" },
                { "key": "hasOPD", "value": "true", "type": "text" },
                { "key": "hasLab", "value": "true", "type": "text" },
                { "key": "hasMedicalStore", "value": "true", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Super Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.token) pm.collectionVariables.set('superAdminToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/super-admin/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{superAdminEmail}}\",\n  \"password\": \"{{superAdminPassword}}\"\n}"
            }
          }
        },
        {
          "name": "Register Clinic (By Super Admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{superAdminToken}}" }],
            "url": "{{baseUrl}}/api/super-admin/clinics/register",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "clinicName", "value": "{{clinicName}}", "type": "text" },
                { "key": "ownerName", "value": "Dr Flow Owner", "type": "text" },
                { "key": "email", "value": "{{clinicPublicEmail}}", "type": "text" },
                { "key": "phoneNumber", "value": "{{clinicPublicPhone}}", "type": "text" },
                { "key": "registrationNumber", "value": "FLOW-REG-001", "type": "text" },
                { "key": "address", "value": "Main Road", "type": "text" },
                { "key": "country", "value": "India", "type": "text" },
                { "key": "state", "value": "Maharashtra", "type": "text" },
                { "key": "city", "value": "Pune", "type": "text" },
                { "key": "fullAddress", "value": "Main Road, Pune", "type": "text" },
                { "key": "pincode", "value": "411001", "type": "text" },
                { "key": "adminName", "value": "Clinic Admin", "type": "text" },
                { "key": "adminEmail", "value": "{{clinicAdminEmail}}", "type": "text" },
                { "key": "password", "value": "{{clinicAdminPassword}}", "type": "text" },
                { "key": "subscriptionPlan", "value": "premium", "type": "text" },
                { "key": "clinicType", "value": "general", "type": "text" },
                { "key": "doctorCount", "value": "2", "type": "text" },
                { "key": "staffCount", "value": "5", "type": "text" },
                { "key": "consultationFee", "value": "300", "type": "text" },
                { "key": "openingHours", "value": "09:00-19:00", "type": "text" },
                { "key": "hasOPD", "value": "true", "type": "text" },
                { "key": "hasLab", "value": "true", "type": "text" },
                { "key": "hasMedicalStore", "value": "true", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "(Optional) Get Clinics",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json?.data?.[0]?._id;",
                  "if (id) pm.collectionVariables.set('clinicId', id);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{superAdminToken}}" }],
            "url": "{{baseUrl}}/api/super-admin/clinics"
          }
        },
        {
          "name": "Clinic Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.token) pm.collectionVariables.set('clinicToken', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/clinic-admin/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clinicAdminEmail}}\",\n  \"password\": \"{{clinicAdminPassword}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "1) Patient Registration",
      "item": [
        {
          "name": "Create Patient",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const pid = json?.data?.patient?._id;",
                  "if (pid) pm.collectionVariables.set('patientId', pid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/patients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Flow Demo Patient\",\n  \"age\": 31,\n  \"gender\": \"male\",\n  \"phone\": \"9898989898\",\n  \"address\": \"Flow Street\"\n}"
            }
          }
        },
        {
          "name": "Get Patients",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/patients"
          }
        }
      ]
    },
    {
      "name": "2) Visit Booking + Queue",
      "item": [
        {
          "name": "Book Visit (today)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const visit = json?.data;",
                  "if (visit?._id) pm.collectionVariables.set('visitId', visit._id);",
                  "if (visit?.serialNo) pm.collectionVariables.set('serialNo', String(visit.serialNo));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/book",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"visitDate\": \"{{today}}\",\n  \"bookingSource\": \"clinic\",\n  \"visitType\": \"new\"\n}"
            }
          }
        },
        {
          "name": "Get Date Visits",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits?date={{today}}"
          }
        },
        {
          "name": "Get Visit By Serial",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/queue/by-serial?date={{today}}&serialNo={{serialNo}}"
          }
        },
        {
          "name": "Update Visit Status -> arrived",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"arrived\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3) Reception OPD Desk",
      "item": [
        {
          "name": "Update OPD Payment",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/opd-payment",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"paid\",\n  \"amount\": 300\n}"
            }
          }
        },
        {
          "name": "Update Vitals",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/vitals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bp\": \"120/80\",\n  \"temperature\": 98.4,\n  \"weight\": 69\n}"
            }
          }
        },
        {
          "name": "Update Visit Status -> with_doctor",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"with_doctor\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "4) Doctor Consultation",
      "item": [
        {
          "name": "Save Consultation",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/consultation",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Acute Viral Infection\",\n  \"description\": \"Mild fever, body ache, throat irritation\",\n  \"parhej\": \"Avoid cold drinks and oily food\",\n  \"medicineDays\": {{medicineDays}}\n}"
            }
          }
        },
        {
          "name": "Create/Update Test Catalog",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/master/tests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"CBC\",\n  \"defaultFee\": 450\n}"
            }
          }
        }
      ]
    },
    {
      "name": "5) Tests + Lab Queue",
      "item": [
        {
          "name": "Add Tests",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const tid = json?.data?.[0]?._id;",
                  "if (tid) pm.collectionVariables.set('testId', tid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/tests",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tests\": [\n    { \"name\": \"CBC\" },\n    { \"name\": \"CRP\", \"fee\": 550, \"notes\": \"Urgent\" }\n  ]\n}"
            }
          }
        },
        {
          "name": "Lab Queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/queues/lab?date={{today}}"
          }
        },
        {
          "name": "Update Test Report (multipart)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/tests/{{testId}}/report",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "status", "value": "ready", "type": "text" },
                { "key": "notes", "value": "Report generated", "type": "text" },
                { "key": "reportFile", "type": "file", "src": "" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "6) Medicines + Medical Store",
      "item": [
        {
          "name": "Add Medicines",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const mid = json?.data?.[0]?._id;",
                  "if (mid) pm.collectionVariables.set('medicineId', mid);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/medicines",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"medicines\": [\n    {\n      \"name\": \"Paracetamol 650\",\n      \"timing\": \"after_food\",\n      \"frequencyPerDay\": 2,\n      \"days\": {{medicineDays}}\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Medicine Suggestion",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/master/medicines/suggest?q=para"
          }
        },
        {
          "name": "Medical Store Queue",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/queues/medical-store?date={{today}}"
          }
        },
        {
          "name": "Update Medicine Billing",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/medicines/{{medicineId}}/billing",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unitPrice\": 12,\n  \"quantity\": 10,\n  \"paymentStatus\": \"paid\",\n  \"storeStatus\": \"completed\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "7) Case Closure + Revisit + Timeline",
      "item": [
        {
          "name": "Update Case Status -> in_progress",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/case-status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"caseStatus\": \"in_progress\"\n}"
            }
          }
        },
        {
          "name": "Revisit Due List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/revisits/due?date={{followUpDate}}"
          }
        },
        {
          "name": "Patient Timeline",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{clinicToken}}" }],
            "url": "{{baseUrl}}/api/visits/patient/{{patientId}}/timeline"
          }
        },
        {
          "name": "Update Case Status -> completed",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/case-status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"caseStatus\": \"completed\"\n}"
            }
          }
        },
        {
          "name": "Final Visit Status -> done",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{clinicToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/api/visits/{{visitId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"done\"\n}"
            }
          }
        }
      ]
    }
  ]
}
